# ==== Gemini Live API (voice layer: STT + TTS only) ====
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here
# Half-cascade live model works best for the STT/TTS-only pattern.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025
GEMINI_LIVE_MODEL_FALLBACKS=gemini-2.5-flash-native-audio-preview-12-2025,gemini-2.5-flash-native-audio-latest,gemini-3.1-flash-live-preview
# TTS voice: Puck, Charon, Kore, Fenrir, Aoede, Leda, Orus, Zephyr ...
GEMINI_TTS_VOICE=Charon

# ==== Reasoning brain (OpenAI or any OpenAI-compatible endpoint) ====
OPENAI_API_KEY=your_openai_api_key
# Point this at any OpenAI-compatible API (Azure, Groq, Together, local vLLM...)
OPENAI_BASE_URL=https://api.openai.com/v1
# Fast model for the intent router; stronger model for legal reasoning.
ROUTER_MODEL=gpt-4o-mini
REASONING_MODEL=gpt-4o

# ==== Precedent retrieval (Indian case law) — FREE by default, no token ====
# Free sources used out of the box: Wikipedia (landmark judgments) + DuckDuckGo
# web search (surfaces Indian Kanoon / SCI / eCourts links) + a landmark seed
# corpus. You do NOT need any key for these.
ENABLE_WIKIPEDIA=true
ENABLE_WEB_SEARCH=true

# Indian Kanoon's official API is PAID (https://api.indiankanoon.org/). Leave
# blank to stay fully free; set a token only if you have one.
INDIANKANOON_API_TOKEN=

# Indian Kanoon's public search page is technically reachable for free, but
# their robots.txt disallows /search/. This scraper is therefore OFF by default.
# Set to true only if you accept scraping a robots-disallowed path.
ENABLE_INDIANKANOON_SCRAPE=false

RETRIEVAL_TIMEOUT_S=8

# ==== Server / behaviour ====
HOST=127.0.0.1
PORT=8000
# Keep spoken replies short for natural voice UX.
MAX_SPOKEN_SENTENCES=3
